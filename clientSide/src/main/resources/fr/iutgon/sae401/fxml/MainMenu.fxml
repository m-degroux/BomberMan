<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           fx:controller="fr.iutgon.sae401.clientSide.controllers.MainMenuController"
           styleClass="root-menu">

    <VBox alignment="CENTER" spacing="18" maxWidth="520" styleClass="menu-panel">
        <padding>
            <Insets top="35" right="35" bottom="35" left="35"/>
        </padding>

        <Label text="BOMBERMAN" styleClass="game-title"/>
        <Label text="EXPLODING GAME" styleClass="game-subtitle"/>

        <Region minHeight="12"/>

        <Button fx:id="localButton" text="JOUER EN LOCAL"
                prefWidth="320"
                prefHeight="56"
                styleClass="retro-button"
                onAction="#onLocalClicked"
                disable="false"/>

        <Button fx:id="multiplayerButton" text="MULTIJOUEUR"
                prefWidth="320"
                prefHeight="56"
                styleClass="retro-button"
                onAction="#onMultiplayerClicked"
                disable="true"/>

        <Button text="PARAMÈTRES"
                prefWidth="320"
                prefHeight="56"
                styleClass="retro-button"
                onAction="#onSettingsClicked"/>

        <Button text="QUITTER"
                prefWidth="320"
                prefHeight="56"
                styleClass="retro-button"
                onAction="#onQuitClicked"/>

        <Region minHeight="18"/>

        <HBox alignment="CENTER" spacing="10">
            <Label text="Serveur IP :" styleClass="footer-text"/>
            <TextField fx:id="ipTextField" text="localhost" prefWidth="150" promptText="Ex: 127.0.0.1"/>
            <Button fx:id="connectButton" text="Connecter" onAction="#onConnectClicked" styleClass="retro-button"/>
        </HBox>

        <Region minHeight="5"/>

        <Label fx:id="keysInfoLabel" text="↑ ↓ ← → POUR BOUGER  |  ESPACE POUR POSER UNE BOMBE"
               styleClass="footer-text"/>

        <Label fx:id="clientSlotLabel" text="" styleClass="footer-small"/>

    </VBox>

</StackPane>
