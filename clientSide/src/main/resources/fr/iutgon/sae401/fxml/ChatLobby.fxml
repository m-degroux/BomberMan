<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<VBox xmlns:fx="http://javafx.com/fxml/1" styleClass="root-menu" fx:controller="fr.iutgon.sae401.clientSide.controllers.ChatLobbyController" prefHeight="400.0"
      prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/21">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <children>
        <Label fx:id="arenaNameLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Arena-0">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>

        <Label fx:id="countdownLabel" alignment="CENTER" maxWidth="1.7976931348623157E308"
               managed="false" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ffd166;"
               text="" visible="false"/>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Ton Pseudo :" />
                <TextField fx:id="pseudoField" promptText="Entre un nom..." prefWidth="200.0" />
            </children>
        </HBox>

        <HBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <ListView fx:id="playerListView" prefHeight="273.0" prefWidth="346.0"/>
                <TextArea fx:id="chatHistoryArea" editable="false" wrapText="true" HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>

        <BorderPane>
            <left>
                <Button fx:id="leaveButton" mnemonicParsing="false" text="Quitter" styleClass="danger-button" BorderPane.alignment="BOTTOM_LEFT"/>
            </left>
            <right>
                <VBox alignment="BOTTOM_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
                    <children>
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="messageInputField" prefHeight="26.0" prefWidth="288.0"
                                           promptText="Votre message..." HBox.hgrow="ALWAYS"/>

                                <Button fx:id="sendButton" mnemonicParsing="false" text="Envoyer" styleClass="retro-button"/>
                            </children>
                        </HBox>
                        <HBox spacing="10.0" alignment="BOTTOM_RIGHT">
                            <children>
                                <Button fx:id="readyButton" mnemonicParsing="false" text="Prêt" styleClass="retro-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </right>
        </BorderPane>
    </children>
</VBox>
